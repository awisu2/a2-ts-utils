{
  // load other setting files
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es2022",

    // using library for type checking in editor.
    // DOM: Document Object Model (browser apis)
    // EsNext: latest javascript functions
    "lib": ["esnext"],

    // pnpm add -Dw @types/node
    // 両対応のため、dom または node のどちらかを選択する必要があり、nodeで対応している
    "types": ["node"],

    // output directory
    "outDir": "./dist",
    "rootDir": "./src",

    "composite": true
  },
  "include": ["src/**/*.ts"]
}