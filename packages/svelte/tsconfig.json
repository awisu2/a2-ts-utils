{
  // load other setting files
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "es2022",

    // usable library settings
    // DOM: Document Object Model (browser apis)
    // EsNext: latest javascript functions
    "lib": ["dom", "esnext"],

    // pnpm add -Dw @types/node
    "types": ["svelte"],

    // use bundler(e.g. vite, webpack) module resolution strategy
    // "moduleResolution": "bundler",

    // output directory
    "outDir": "./dist",
    "rootDir": "./src",
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"],
  "references": [
    {"path": "../browser"},
  ]
}